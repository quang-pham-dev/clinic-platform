{
  "name": "@clinic-platform/api",
  "version": "0.1.0",
  "description": "NestJS REST API — P1 Clinic Appointment Booking System",
  "author": "Quang Pham <quangpham.developer@gmail.com>",
  "private": true,
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "nest start",
    "start:prod": "node dist/main",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --max-warnings 0 --fix",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "check-types": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest run --coverage --passWithNoTests",
    "migration:generate": "NODE_OPTIONS=\"-r tsconfig-paths/register\" typeorm-ts-node-commonjs migration:generate",
    "migration:run": "NODE_OPTIONS=\"-r tsconfig-paths/register\" typeorm-ts-node-commonjs migration:run -d src/database/data-source.ts",
    "migration:revert": "NODE_OPTIONS=\"-r tsconfig-paths/register\" typeorm-ts-node-commonjs migration:revert -d src/database/data-source.ts",
    "migration:show": "NODE_OPTIONS=\"-r tsconfig-paths/register\" typeorm-ts-node-commonjs migration:show -d src/database/data-source.ts",
    "seed": "ts-node -r tsconfig-paths/register src/database/seeds/seed.ts"
  },
  "dependencies": {
    "@clinic-platform/logger": "workspace:*",
    "@clinic-platform/types": "workspace:*",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/cache-manager": "^3.1.0",
    "@nestjs/common": "catalog:nestjs",
    "@nestjs/config": "catalog:nestjs",
    "@nestjs/core": "catalog:nestjs",
    "@nestjs/event-emitter": "^3.0.1",
    "@nestjs/jwt": "catalog:nestjs",
    "@nestjs/passport": "catalog:nestjs",
    "@nestjs/platform-express": "catalog:nestjs",
    "@nestjs/platform-socket.io": "^11.1.18",
    "@nestjs/swagger": "catalog:nestjs",
    "@nestjs/throttler": "catalog:nestjs",
    "@nestjs/typeorm": "catalog:nestjs",
    "@nestjs/websockets": "^11.1.18",
    "@sendgrid/mail": "^8.1.6",
    "bcrypt": "catalog:nestjs",
    "bullmq": "^5.73.2",
    "cache-manager": "^7.2.8",
    "cache-manager-ioredis-yet": "^2.1.2",
    "class-transformer": "catalog:nestjs",
    "class-validator": "catalog:nestjs",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.3.1",
    "handlebars": "^4.7.9",
    "helmet": "catalog:nestjs",
    "ioredis": "catalog:nestjs",
    "joi": "^18.1.2",
    "passport": "catalog:nestjs",
    "passport-jwt": "catalog:nestjs",
    "passport-local": "catalog:nestjs",
    "pg": "catalog:nestjs",
    "reflect-metadata": "catalog:nestjs",
    "rxjs": "catalog:nestjs",
    "socket.io": "^4.8.3",
    "twilio": "^5.13.1",
    "typeorm": "catalog:nestjs"
  },
  "devDependencies": {
    "@clinic-platform/eslint-config": "workspace:*",
    "@clinic-platform/prettier-config": "workspace:*",
    "@clinic-platform/typescript-config": "workspace:*",
    "@clinic-platform/vitest-config": "workspace:*",
    "@nestjs/cli": "catalog:nestjs",
    "@nestjs/schematics": "catalog:nestjs",
    "@nestjs/testing": "catalog:nestjs",
    "@types/bcrypt": "catalog:nestjs",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.0",
    "@types/node": "catalog:",
    "@types/passport-jwt": "catalog:nestjs",
    "@types/passport-local": "catalog:nestjs",
    "@types/supertest": "catalog:testing",
    "@vitest/coverage-v8": "catalog:testing",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "source-map-support": "^0.5.21",
    "supertest": "catalog:testing",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "catalog:",
    "unplugin-swc": "catalog:testing",
    "vitest": "catalog:testing"
  },
  "prettier": "@clinic-platform/prettier-config/base"
}
