# ─── API Configuration ────────────────────────────────────────────────
# Base URL for the backend API. Uses Vite proxy in dev, absolute URL in prod.
VITE_API_BASE_URL=/api/v1

# ─── Backend Server (for Vite Proxy in development) ───────────────────
# The target backend server that the Vite proxy forwards /api requests to.
# This is NOT exposed to the client bundle; only used by Vite dev server.
VITE_API_PROXY_TARGET=http://localhost:3000
