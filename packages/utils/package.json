{
  "name": "@clinic-platform/utils",
  "version": "0.1.0",
  "license": "MIT",
  "description": "Shared utility functions for the Clinic Platform monorepo",
  "repository": {
    "type": "git",
    "url": "https://github.com/quang-pham-dev/clinic-platform.git"
  },
  "homepage": "https://github.com/quang-pham-dev/clinic-platform",
  "bugs": {
    "url": "https://github.com/quang-pham-dev/clinic-platform/issues"
  },
  "keywords": [
    "utils",
    "typescript",
    "helpers",
    "monorepo"
  ],
  "private": false,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --max-warnings 0 --fix",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "check-types": "tsc --noEmit",
    "clean": "rm -rf dist node_modules",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage --passWithNoTests"
  },
  "devDependencies": {
    "@clinic-platform/eslint-config": "workspace:*",
    "@clinic-platform/prettier-config": "workspace:*",
    "@clinic-platform/typescript-config": "workspace:*",
    "@clinic-platform/vitest-config": "workspace:*",
    "@types/node": "catalog:",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:testing",
    "@vitest/coverage-v8": "catalog:testing",
    "@vitest/ui": "catalog:testing"
  },
  "prettier": "@clinic-platform/prettier-config/base"
}
