{
  "name": "clinic-platform",
  "description": "Healthcare Clinic Platform — multi-app monorepo with Turborepo and pnpm",
  "private": true,
  "version": "0.1.0",
  "author": "Quang Pham <quangpham.developer@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/quang-pham-dev/clinic-platform.git"
  },
  "homepage": "https://github.com/quang-pham-dev/clinic-platform",
  "bugs": {
    "url": "https://github.com/quang-pham-dev/clinic-platform/issues"
  },
  "packageManager": "pnpm@10.25.0",
  "engines": {
    "node": ">=20",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "dev": "turbo watch dev",
    "build": "turbo run build",
    "build:apps": "turbo run build --filter=\"./apps/*\"",
    "build:packages": "turbo run build --filter=\"./packages/*\"",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "format": "turbo run format",
    "format:fix": "turbo run format:fix",
    "check-types": "turbo run check-types",
    "test": "turbo run test",
    "test:watch": "turbo run test:watch",
    "test:coverage": "turbo run test:coverage",
    "clean": "turbo run clean && rm -rf node_modules",
    "prepare": "husky"
  },
  "devDependencies": {
    "@clinic-platform/eslint-config": "workspace:*",
    "@clinic-platform/prettier-config": "workspace:*",
    "@clinic-platform/typescript-config": "workspace:*",
    "@clinic-platform/vitest-config": "workspace:*",
    "@commitlint/cli": "catalog:",
    "@commitlint/config-conventional": "catalog:",
    "@trivago/prettier-plugin-sort-imports": "6.0.2",
    "eslint": "catalog:",
    "husky": "catalog:",
    "lint-staged": "catalog:",
    "prettier": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "prettier": "@clinic-platform/prettier-config/base"
}
